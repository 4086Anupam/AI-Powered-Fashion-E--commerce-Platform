# Root level gitignore

# Environment files
.env
.env.local
.env.*.local
*.env

# IDE
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
target/
*.jar
!*.jar.original

# Dependencies
node_modules/

# Sensitive files
**/application.properties
!**/application.properties.example
**/secrets.*
**/credentials.*
